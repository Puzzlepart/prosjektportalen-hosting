{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/Puzzlepart/prosjektportalen-hosting/main/schema/pppkg-manifest.schema.json",
  "title": "Prosjektportalen Package Manifest",
  "description": "Schema for validating manifest.json in Prosjektportalen package files (.pppkg)",
  "type": "object",
  "required": ["id", "name", "version", "type", "author"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "URL to this JSON Schema"
    },
    "id": {
      "type": "string",
      "description": "Unique package identifier (e.g., 'pp-standard-prosjektmal')",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "minLength": 3
    },
    "name": {
      "type": "string",
      "description": "Human-readable package name",
      "minLength": 1,
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "description": "Brief description of the package (shown in catalog and wizard)",
      "maxLength": 500
    },
    "version": {
      "type": "string",
      "description": "Package version in semver format (e.g., '1.2.0')",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "author": {
      "type": "string",
      "description": "Package author/publisher name",
      "minLength": 1
    },
    "license": {
      "type": "string",
      "description": "License identifier (e.g., 'MIT', 'Apache-2.0')",
      "examples": ["MIT", "Apache-2.0", "GPL-3.0", "Proprietary"]
    },
    "minPPVersion": {
      "type": "string",
      "description": "Minimum required Prosjektportalen version (semver)",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "thumbnail": {
      "type": "string",
      "description": "Relative path to thumbnail image (16:9, min 600x338px)",
      "pattern": "^[^/].*\\.(png|jpg|jpeg|webp)$"
    },
    "icon": {
      "type": "string",
      "description": "Fluent UI icon name used as the Maloppsett item icon (IconName) on import (e.g. 'Page', 'BuildDefinition')"
    },
    "tags": {
      "type": "array",
      "description": "Tags for categorization and filtering",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "type": {
      "type": "string",
      "description": "Package type",
      "enum": ["template", "extension", "content"]
    },
    "provisioning": {
      "type": "object",
      "description": "Provisioning configuration",
      "properties": {
        "hubTemplate": {
          "type": "string",
          "description": "Relative path to hub-level provisioning template (sp-js-provisioning format)",
          "pattern": "^provisioning/.+\\.json$"
        },
        "template": {
          "type": "string",
          "description": "Relative path to project-level provisioning template (sp-js-provisioning format)",
          "pattern": "^provisioning/.+\\.json$"
        },
        "projectContentTypeId": {
          "type": "string",
          "description": "Content type ID (defined by hubTemplate) to set as GtProjectContentType on the Maloppsett item when imported",
          "pattern": "^0x[0-9A-Fa-f]+$"
        },
        "extensions": {
          "type": "array",
          "description": "Project extensions (prosjekttillegg)",
          "items": {
            "type": "object",
            "required": ["id", "name", "file"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique extension identifier",
                "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
              },
              "name": {
                "type": "string",
                "description": "Extension display name",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "description": "Extension description"
              },
              "file": {
                "type": "string",
                "description": "Relative path to extension JSON file",
                "pattern": "^provisioning/extensions/.+\\.json$"
              },
              "optional": {
                "type": "boolean",
                "description": "Whether this extension is optional for users",
                "default": true
              },
              "defaultSelected": {
                "type": "boolean",
                "description": "Whether this extension is selected by default in wizard",
                "default": false
              }
            }
          }
        },
        "listContent": {
          "type": "array",
          "description": "List content configurations (Listeinnhold) created on the hub and linked to the Maloppsett item. Each config copies rows from a hub sourceList into a project's destinationList during project setup.",
          "items": {
            "type": "object",
            "required": ["title", "sourceList"],
            "properties": {
              "title": {
                "type": "string",
                "description": "Title of the Listeinnhold item (also the upsert key)",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "description": "List content description (GtDescription)"
              },
              "sourceList": {
                "type": "string",
                "description": "Hub list to copy rows from (GtLccSourceList) — typically a list provisioned by this package's hubTemplate",
                "minLength": 1
              },
              "destinationList": {
                "type": "string",
                "description": "Project list to copy rows into (GtLccDestinationList). Defaults to sourceList when omitted."
              },
              "fields": {
                "type": "string",
                "description": "Comma-separated internal names of the columns to copy (GtLccFields), or '-' for none"
              },
              "default": {
                "type": "boolean",
                "description": "Selected by default in the setup wizard (GtLccDefault)",
                "default": false
              },
              "hidden": {
                "type": "boolean",
                "description": "Hidden from the setup wizard (GtLccHidden)",
                "default": false
              },
              "locked": {
                "type": "boolean",
                "description": "Locked (cannot be deselected) in the setup wizard (GtLccLocked)",
                "default": false
              }
            }
          }
        }
      }
    },
    "content": {
      "type": "object",
      "description": "Standard content configuration",
      "properties": {
        "items": {
          "type": "array",
          "description": "Content items to be provisioned",
          "items": {
            "type": "object",
            "required": ["id", "name", "sourceFile", "targetList"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique content item identifier",
                "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
              },
              "name": {
                "type": "string",
                "description": "Content item display name",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "description": "Content item description"
              },
              "sourceFile": {
                "type": "string",
                "description": "Relative path to content JSON file",
                "pattern": "^content/.+\\.json$"
              },
              "targetList": {
                "type": "string",
                "description": "Target SharePoint list name",
                "minLength": 1
              },
              "optional": {
                "type": "boolean",
                "description": "Whether this content is optional",
                "default": true
              },
              "defaultSelected": {
                "type": "boolean",
                "description": "Whether this content is selected by default in wizard",
                "default": true
              }
            }
          }
        }
      }
    },
    "changelog": {
      "type": "string",
      "description": "Relative path to changelog file",
      "pattern": "^CHANGELOG\\.md$"
    }
  }
}
