{
  "$schema": "https://raw.githubusercontent.com/Puzzlepart/prosjektportalen-hosting/main/schema/pppkg-manifest.schema.json",
  "id": "pp-standardmal",
  "name": "Standardmal",
  "description": "Komplett prosjektmal med fasesjekkliste, interessentregister, usikkerhetshåndtering, leveransestyring og dokumenthåndtering. Inkluderer integrasjon med Microsoft Planner for oppgavestyring.",
  "version": "1.0.0",
  "author": "Puzzlepart",
  "license": "MIT",
  "minPPVersion": "1.10.0",
  "thumbnail": "thumbnail.png",
  "tags": ["standard", "prosjektledelse", "SharePoint"],
  "type": "template",
  "provisioning": {
    "hubTemplate": "provisioning/hub-template.json",
    "template": "provisioning/template.json",
    "extensions": [
      {
        "id": "enkelt-prosjekt",
        "name": "Enkelt Prosjekt",
        "description": "Oppsett for enkelt prosjekt med standard menypunkter",
        "file": "provisioning/extensions/EnkeltProsjekt.json",
        "optional": true,
        "defaultSelected": false
      },
      {
        "id": "enkel-venstremeny",
        "name": "Enkel Venstremeny",
        "description": "Forenklet venstremeny med de viktigste prosjektkoblingene",
        "file": "provisioning/extensions/EnkelVenstremeny.json",
        "optional": true,
        "defaultSelected": true
      }
    ]
  },
  "content": {
    "items": [
      {
        "id": "phase-checklist",
        "name": "Fasesjekkliste",
        "description": "12 sjekkpunkter fordelt på prosjektfasene",
        "sourceFile": "content/phase-checklist.json",
        "targetList": "Fasesjekkliste",
        "optional": false
      },
      {
        "id": "planner-tasks",
        "name": "Planneroppgaver",
        "description": "8 standardoppgaver for prosjektoppstart",
        "sourceFile": "content/planner-tasks.json",
        "targetList": "Planneroppgaver",
        "optional": true,
        "defaultSelected": true
      },
      {
        "id": "document-templates",
        "name": "Dokumentmaler",
        "description": "Standardmaler for prosjektdokumenter",
        "sourceFile": "content/document-templates.json",
        "targetList": "Dokumentmaler",
        "optional": true,
        "defaultSelected": false
      }
    ]
  },
  "changelog": "CHANGELOG.md"
}
