{
  "$schema": "../../schema/pppkg-manifest.schema.json",
  "id": "pp-it-prosjekt",
  "name": "IT-prosjekt",
  "description": "Prosjektmal for IT- og systemutviklingsprosjekter med smidig oppsett: sprintoppgaver, backlog-håndtering og kvalitetssjekkliste for leveranser.",
  "version": "1.1.0",
  "author": "Puzzlepart",
  "license": "MIT",
  "minPPVersion": "1.11.0",
  "thumbnail": "thumbnail.png",
  "icon": "Code",
  "tags": ["IT", "smidig", "prosjektledelse"],
  "type": "template",
  "provisioning": {
    "hubTemplate": "provisioning/hub-template.json",
    "template": "provisioning/template.json"
  },
  "content": {
    "items": [
      {
        "id": "sprint-oppgaver",
        "name": "Sprintoppgaver",
        "description": "Standardoppgaver for oppstart av en sprint",
        "sourceFile": "content/sprint-oppgaver.json",
        "targetList": "Planneroppgaver",
        "optional": false
      },
      {
        "id": "kvalitetssjekkliste",
        "name": "Kvalitetssjekkliste",
        "description": "Sjekkpunkter for leveransekvalitet",
        "sourceFile": "content/kvalitetssjekkliste.json",
        "targetList": "Fasesjekkliste",
        "optional": true,
        "defaultSelected": true
      }
    ]
  },
  "changelog": "CHANGELOG.md"
}
